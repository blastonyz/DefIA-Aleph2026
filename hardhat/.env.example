# ─── Private Keys ─────────────────────────────────────────────────────────
# Clave privada del deployer / EOA que firma las UserOps
ARBITRUM_SEPOLIA_PK=0x...

# ─── RPCs ─────────────────────────────────────────────────────────────────────
# RPC de Arbitrum Sepolia (debe ser Bundler-compatible, usar Alchemy/Infura)
ALCHEMY_ARB_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# ─── Deployment Flow ──────────────────────────────────────────────────────────
# PASO 1: Deploy AA core contracts → npm run deploy:account
# Después actualizar aquí las direcciones que imprime el script
PAYMASTER_ADDRESS=0x...
FACTORY_ADDRESS=0x...

# PASO 2: Crear una smart account y actualizar aquí su dirección
SMART_ACCOUNT_ADDRESS=0x...

# PASO 3: Deploy executor → npm run deploy:gmx-executor
# El script espera SMART_ACCOUNT_ADDRESS y la actualiza aquí
MOLTBOT_GMX_EXECUTOR=0x...

# ─── UserOp Execution ──────────────────────────────────────────────────────────
# Estrategia de ejecución de GMX trades (raw-noop | gmx-onreport)
MOLTBOT_STRATEGY=gmx-onreport

# Acción de GMX (long | short | close)
MOLTBOT_GMX_ACTION=long

# ─── EntryPoint ───────────────────────────────────────────────────────────────
# EntryPoint v0.7 (predeployed en Arbitrum Sepolia)
ENTRYPOINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032

# Monto a depositar en EntryPoint (en ETH)
DEPOSIT_AMOUNT=0.01


# Si true, execute.ts adjunta paymaster en la UserOp
USE_PAYMASTER=true

# Estrategia de ejecución para execute.ts
# raw-noop: no-op, gmx-onreport: llama onReport en el executor
MOLTBOT_STRATEGY=raw-noop

# Dirección del executor destino (requerida cuando MOLTBOT_STRATEGY=gmx-onreport)
MOLTBOT_GMX_EXECUTOR=0x...

# Acción reportada al executor: long | short | close
MOLTBOT_GMX_ACTION=long
